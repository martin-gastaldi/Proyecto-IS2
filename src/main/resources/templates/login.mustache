<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión — Universidad</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy:     #0d1b3e;
            --navy-mid: #1a2f5e;
            --navy-soft:#243872;
            --gold:     #c9973a;
            --gold-lt:  #e8bb6a;
            --gold-pale:#fdf3e0;
            --cream:    #faf8f4;
            --muted:    #6b7280;
            --border:   #e5e7eb;
            --red:      #dc2626;
            --green:    #15803d;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ── LEFT PANEL ── */
        .panel-left {
            display: none;
            width: 52%;
            position: relative;
            background: var(--navy);
            overflow: hidden;
        }

        @media (min-width: 1024px) { .panel-left { display: flex; flex-direction: column; justify-content: flex-end; } }

        .panel-left img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .18;
        }

        /* Decorative geometric shapes */
        .geo {
            position: absolute;
            border: 1px solid rgba(201,151,58,.25);
            border-radius: 2px;
        }
        .geo-1 { width: 260px; height: 260px; top: -60px; left: -60px; transform: rotate(20deg); }
        .geo-2 { width: 180px; height: 180px; top: 80px; left: 120px; transform: rotate(10deg); border-color: rgba(201,151,58,.15); }
        .geo-3 { width: 320px; height: 320px; bottom: 100px; right: -80px; transform: rotate(-15deg); border-color: rgba(255,255,255,.08); }

        .gold-line {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

        .panel-left-content {
            position: relative;
            z-index: 2;
            padding: 3rem 3.5rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(201,151,58,.15);
            border: 1px solid rgba(201,151,58,.35);
            border-radius: 100px;
            padding: 6px 16px;
            font-size: 12px;
            font-weight: 500;
            color: var(--gold-lt);
            letter-spacing: .05em;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }

        .badge-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--gold);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .3; }
        }

        .panel-left h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.2rem, 3.5vw, 3rem);
            color: #fff;
            line-height: 1.2;
            margin-bottom: 1.25rem;
        }

        .panel-left h1 em {
            font-style: italic;
            color: var(--gold-lt);
        }

        .panel-left p {
            color: rgba(255,255,255,.6);
            font-size: 1rem;
            line-height: 1.75;
            max-width: 380px;
            font-weight: 300;
        }

        .stats {
            display: flex;
            gap: 2rem;
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,255,255,.1);
        }

        .stat-num {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            color: var(--gold-lt);
        }

        .stat-label {
            font-size: 12px;
            color: rgba(255,255,255,.45);
            font-weight: 300;
            letter-spacing: .02em;
            margin-top: 2px;
        }

        /* ── RIGHT PANEL ── */
        .panel-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            background: var(--cream);
        }

        /* Subtle dot grid background */
        .panel-right::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
            background-size: 28px 28px;
            opacity: .35;
        }

        .form-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 440px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2.75rem 2.5rem;
            box-shadow:
                0 1px 2px rgba(0,0,0,.04),
                0 4px 12px rgba(0,0,0,.06),
                0 16px 40px rgba(0,0,0,.06);
            animation: slideUp .5s ease both;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Top gold accent bar */
        .form-card::before {
            content: '';
            position: absolute;
            top: 0; left: 2rem; right: 2rem;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold-lt) 70%, transparent);
            border-radius: 0 0 2px 2px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 2rem;
        }

        .brand-icon {
            width: 44px; height: 44px;
            background: var(--navy);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
        }

        .brand-icon::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 2px;
            background: var(--gold);
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            color: var(--navy);
            line-height: 1.2;
        }

        .brand-sub {
            font-size: 11px;
            color: var(--muted);
            font-weight: 300;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .form-heading {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            color: var(--navy);
            margin-bottom: .4rem;
        }

        .form-sub {
            font-size: .9rem;
            color: var(--muted);
            font-weight: 300;
            margin-bottom: 2rem;
        }

        /* Alerts */
        .alert {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: .85rem 1rem;
            border-radius: 10px;
            font-size: .875rem;
            margin-bottom: 1.25rem;
            line-height: 1.5;
        }

        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: var(--green); }
        .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: var(--red); }

        .alert-icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }

        /* Form fields */
        .field { margin-bottom: 1.25rem; }

        label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: var(--navy);
            letter-spacing: .04em;
            text-transform: uppercase;
            margin-bottom: .5rem;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%; transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1rem;
            pointer-events: none;
            transition: color .2s;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            height: 48px;
            padding: 0 44px 0 44px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            color: var(--navy);
            background: #fafafa;
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        input:focus {
            border-color: var(--navy-soft);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(36,56,114,.08);
        }

        input:focus + .input-icon,
        .input-wrap:focus-within .input-icon { color: var(--navy-soft); }

        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%; transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9ca3af;
            padding: 0;
            font-size: 1rem;
            transition: color .2s;
            display: flex;
        }

        .toggle-pw:hover { color: var(--navy); }

        .forgot {
            display: block;
            text-align: right;
            font-size: .8rem;
            color: var(--gold);
            font-weight: 500;
            text-decoration: none;
            margin-top: .5rem;
            transition: color .2s;
        }

        .forgot:hover { color: var(--navy); }

        /* Submit button */
        .btn-submit {
            width: 100%;
            height: 50px;
            margin-top: .5rem;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            font-weight: 600;
            letter-spacing: .02em;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: background .25s, transform .15s;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(201,151,58,.25) 50%, transparent 100%);
            transform: translateX(-100%);
            transition: transform .6s ease;
        }

        .btn-submit:hover { background: var(--navy-mid); }
        .btn-submit:hover::before { transform: translateX(100%); }
        .btn-submit:active { transform: scale(.98); }

        .btn-content {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.5rem 0 1.25rem;
        }

        .divider-line { flex: 1; height: 1px; background: var(--border); }

        .divider-text { font-size: .8rem; color: #9ca3af; font-weight: 300; white-space: nowrap; }

        /* Footer links */
        .form-footer {
            text-align: center;
        }

        .form-footer p { font-size: .875rem; color: var(--muted); }

        .link-primary {
            color: var(--navy);
            font-weight: 600;
            text-decoration: none;
            border-bottom: 1px solid var(--gold);
            padding-bottom: 1px;
            transition: color .2s, border-color .2s;
        }

        .link-primary:hover { color: var(--gold); border-color: transparent; }

        .link-back {
            display: inline-block;
            margin-top: .75rem;
            font-size: .8rem;
            color: #9ca3af;
            text-decoration: none;
            transition: color .2s;
        }

        .link-back:hover { color: var(--navy); }

        /* Password strength dots (visual flair) */
        .pw-strength {
            display: flex;
            gap: 4px;
            margin-top: 6px;
            opacity: 0;
            transition: opacity .3s;
        }

        .pw-strength.visible { opacity: 1; }

        .dot {
            width: 24px; height: 3px;
            border-radius: 2px;
            background: var(--border);
            transition: background .3s;
        }

        .dot.active { background: var(--gold); }
        .dot.strong { background: #15803d; }
    </style>
</head>
<body>

<!-- ── LEFT PANEL ── -->
<div class="panel-left">
    <div class="gold-line"></div>
    <img src="/img/universidad.png" alt="Campus universitario">
    <div class="geo geo-1"></div>
    <div class="geo geo-2"></div>
    <div class="geo geo-3"></div>

    <div class="panel-left-content">
        <div class="badge">
            <div class="badge-dot"></div>
            Plataforma académica
        </div>

        <h1>Tu futuro comienza <em>aquí.</em></h1>

        <p>Accedé a tu portal institucional, consultá tu historial académico y seguí construyendo tu camino profesional.</p>

        <div class="stats">
            <div>
                <div class="stat-num">12K+</div>
                <div class="stat-label">Estudiantes activos</div>
            </div>
            <div>
                <div class="stat-num">200+</div>
                <div class="stat-label">Programas de estudio</div>
            </div>
            <div>
                <div class="stat-num">98%</div>
                <div class="stat-label">Satisfacción estudiantil</div>
            </div>
        </div>
    </div>
</div>

<!-- ── RIGHT PANEL ── -->
<div class="panel-right">
    <div class="form-card">

        <!-- Brand -->
        <div class="brand">
            <div class="brand-icon">🎓</div>
            <div>
                <div class="brand-name">Portal Académico</div>
                <div class="brand-sub">Acceso institucional</div>
            </div>
        </div>

        <h2 class="form-heading">Bienvenido</h2>
        <p class="form-sub">Ingresá con tus credenciales para continuar</p>

        {{#successMessage}}
        <div class="alert alert-success">
            <span class="alert-icon">✓</span>
            <span>{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="alert alert-error">
            <span class="alert-icon">!</span>
            <span>{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/login" method="post">

            <div class="field">
                <label for="username">Usuario</label>
                <div class="input-wrap">
                    <input
                        type="text"
                        id="username"
                        name="username"
                        required
                        placeholder="tu.usuario@universidad.edu"
                        autocomplete="username">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
            </div>

            <div class="field">
                <label for="password">Contraseña</label>
                <div class="input-wrap">
                    <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        placeholder="••••••••"
                        autocomplete="current-password">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <button type="button" class="toggle-pw" id="togglePw" aria-label="Mostrar contraseña">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
                <div class="pw-strength" id="pwStrength">
                    <div class="dot" id="d1"></div>
                    <div class="dot" id="d2"></div>
                    <div class="dot" id="d3"></div>
                    <div class="dot" id="d4"></div>
                </div>
                <a href="/forgot-password" class="forgot">¿Olvidaste tu contraseña?</a>
            </div>

            <button type="submit" class="btn-submit">
                <div class="btn-content">
                    <span>Iniciar sesión</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
            </button>

        </form>

        <div class="divider">
            <div class="divider-line"></div>
            <span class="divider-text">¿Primera vez?</span>
            <div class="divider-line"></div>
        </div>

        <div class="form-footer">
            <p>¿No tenés cuenta? <a href="/user/create" class="link-primary">Registrate aquí</a></p>
            <a href="/" class="link-back">← Volver al inicio</a>
        </div>

    </div>
</div>

<script>
    // Toggle password visibility
    const pwInput = document.getElementById('password');
    const toggleBtn = document.getElementById('togglePw');
    const eyeIcon = document.getElementById('eyeIcon');

    const eyeOpen  = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    const eyeClose = `<line x1="17.94" y1="17.94" x2="22" y2="22"/><line x1="1" y1="1" x2="6.06" y2="6.06"/><path d="M9.9 4.24A9 9 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M6.24 6.24A18.5 18.5 0 0 0 1 12c0 0 4 8 11 8a9.74 9.74 0 0 0 4.76-1.24"/><line x1="1" y1="1" x2="22" y2="22"/>`;

    toggleBtn.addEventListener('click', () => {
        const isText = pwInput.type === 'text';
        pwInput.type = isText ? 'password' : 'text';
        eyeIcon.innerHTML = isText ? eyeOpen : eyeClose;
    });

    // Password strength indicator
    const pwStrength = document.getElementById('pwStrength');
    const dots = [document.getElementById('d1'), document.getElementById('d2'), document.getElementById('d3'), document.getElementById('d4')];

    pwInput.addEventListener('input', () => {
        const val = pwInput.value;
        if (!val) { pwStrength.classList.remove('visible'); return; }
        pwStrength.classList.add('visible');

        let score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^a-zA-Z0-9]/.test(val)) score++;

        dots.forEach((dot, i) => {
            dot.classList.remove('active', 'strong');
            if (i < score) {
                dot.classList.add(score === 4 ? 'strong' : 'active');
            }
        });
    });
</script>

</body>
</html>