<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Gestión de Materias</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
    background:#FFF;
    min-height:100vh;
    padding:30px;
}

.container{
    max-width:1300px;
    margin:auto;
    background:white;
    border-radius:15px;
    box-shadow:0 10px 30px rgba(0,0,0,.2);
    overflow:hidden;
}

.header{
    padding:30px;
    background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
    color:white;
}

.header h1{
    margin-bottom:10px;
}

.header p{
    opacity:.9;
}

.toolbar{
    padding:25px 30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:15px;
}

.btn{
    text-decoration:none;
    border:none;
    border-radius:8px;
    padding:10px 18px;
    cursor:pointer;
    font-size:14px;
    font-weight:600;
    transition:.3s;
}

.btn:hover{
    transform:translateY(-2px);
}

.btn-primary{
    background:#667eea;
    color:white;
}

.btn-secondary{
    background:#e9ecef;
    color:#333;
}

.btn-warning{
    background:#ffc107;
    color:#222;
}

.btn-danger{
    background:#dc3545;
    color:white;
}

.table-container{
    padding:0 30px 30px 30px;
}

table{
    width:100%;
    border-collapse:collapse;
    overflow:hidden;
    border-radius:10px;
}

thead{
    background:#667eea;
    color:white;
}

th{
    padding:15px;
    text-align:left;
}

td{
    padding:15px;
    border-bottom:1px solid #eee;
}



.actions{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
}

.delete-form{
    display:inline;
}

.footer{
    padding:30px;
    text-align:center;
}

.badge{
    background:#eef2ff;
    color:#667eea;
    padding:5px 10px;
    border-radius:20px;
    font-size:12px;
    font-weight:bold;
}

.empty{
    text-align:center;
    padding:40px;
    color:#777;
}

</style>
</head>
<body>

<div class="container">

    <div class="header">
        <h1>📚 Gestión de Materias</h1>
        <p>Administración de materias y correlatividades</p>
    </div>

    <div class="toolbar">

        <a href="/admin/materias/new"
           class="btn btn-primary">
           ➕ Nueva Materia
        </a>


    </div>

    <div class="table-container">

        <table>

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Materia</th>
                    <th>Año</th>
                    <th>Cuatrimestre</th>
                    <th>Carga Horaria</th>
                    <th>Carrera</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

            {{#materias}}
                <tr>

                    <td>{{id_materia}}</td>

                    <td>
                        <strong>{{nombreMateria}}</strong>
                    </td>

                    <td>{{anio}}</td>

                    <td>{{cuatrimestre}}</td>

                    <td>{{carga_horaria}} hs</td>

                    <td>{{id_carrera}}</td>

                    <td>

                        <div class="actions">

                            <a
                                href="/admin/materias/edit/{{id_materia}}"
                                class="btn btn-warning">
                                ✏️ Editar
                            </a>

                            <a
                                href="/admin/materias/correlativas/{{id_materia}}"
                                class="btn btn-primary">
                                🔗 Correlativas
                            </a>

                            <form
                                action="/admin/materias/delete/{{id_materia}}"
                                method="POST"
                                class="delete-form"
                                onsubmit="return confirmarEliminacion('{{nombreMateria}}')">

                                <button
                                    type="submit"
                                    class="btn btn-danger">
                                    🗑️ Eliminar
                                </button>

                            </form>

                        </div>

                    </td>

                </tr>
            {{/materias}}

            {{^materias}}
                <tr>
                    <td colspan="7" class="empty">
                        No existen materias registradas
                    </td>
                </tr>
            {{/materias}}

            </tbody>

        </table>

    </div>

    <div class="footer">

        <a
            href="/admin/panel"
            class="btn btn-secondary">
            ← Volver al Panel
        </a>

    </div>

</div>

<script>

function confirmarEliminacion(nombreMateria){

    return confirm(
        "¿Está seguro que desea eliminar la materia:\n\n" +
        nombreMateria +
        "\n\nEsta acción no puede deshacerse."
    );
}

</script>

</body>
</html>