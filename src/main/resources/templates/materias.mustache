<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Gestión de Materias</title>

<style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    body{
        font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
        min-height:100vh;
        margin:0;
        padding:30px;
    }

    .container{
        background:white;
        max-width:1100px;
        margin:0 auto;
        border-radius:12px;
        padding:30px;
        box-shadow:0 15px 45px rgba(0,0,0,.18);
    }

    .header h1{
        margin-bottom:10px;
        font-size:2rem;
        color:#333;
    }

    .top-actions{
    display:flex;
    flex-wrap:wrap;
    justify-content:space-between;
    gap:10px;
    margin-bottom:24px;
    align-items:center;
    }

    .filter-row button{
    border:none;
    }
    
    .btn{
    display:inline-block;
    padding:12px 18px;
    border-radius:8px;
    text-decoration:none;
    color:white;
    font-weight:600;
    transition:transform .25s ease, box-shadow .25s ease;
    border:none;
    cursor:pointer;
    }

    .btn:hover{
        transform:translateY(-1px);
        box-shadow:0 10px 20px rgba(0,0,0,.12);
    }

    .btn-primary{
        background:#667eea;
        color:white;
    }

    .btn-secondary{
        background:#6c757d;
        color:white;
    }

    .grid{
        display:grid;
        gap:18px;
    }

    .card{
        border:1px solid #e3e8f0;
        border-radius:14px;
        padding:22px;
        display:grid;
        grid-template-columns:1fr auto;
        gap:18px;
        align-items:flex-start;
        background:#fbfcff;
    }

    .card h2{
        margin:0 0 10px;
        font-size:1.3rem;
        color:#2b2b2b;
        word-wrap:break-word;
        overflow-wrap:break-word;
    }

    .card p{
        margin:6px 0;
        color:#4a4a4a;
        word-wrap:break-word;
        overflow-wrap:break-word;
    }

    .details{
        min-width:0;
    }

    .actions{
        display:grid;
        gap:10px;
        min-width:160px;
    }

    .actions form{
        margin:0;
    }

    .actions a,
    .actions button{
        width:100%;
        min-height:44px;
        padding:12px 14px;
        border:none;
        border-radius:8px;
        text-decoration:none;
        display:flex;
        align-items:center;
        justify-content:center;
        font-size:.95rem;
        cursor:pointer;
        box-sizing:border-box;
    }

    .actions .edit{
        background:#f6c23e;
        color:#111;
    }

    .actions .link{
        background:#667eea;
        color:white;
    }

    .actions .delete{
        background:#e74a3b;
        color:white;
    }

    .empty-state{
        padding:22px;
        background:#f8f9fc;
        border:1px dashed #d1d5db;
        border-radius:14px;
        text-align:center;
        color:#6b7280;
    }

    .filter-row{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    align-items:center;
    margin-bottom:20px;
    }

    .filter-row select{
    padding:12px 14px;
    border:1px solid #cbd5e1;
    border-radius:10px;
    min-width:240px;
    }

    @media (max-width:768px){

        .card{
            grid-template-columns:1fr;
        }

        .actions{
            min-width:100%;
        }

    }

</style>
</head>
<body>
<div class="container">

<div class="top-actions">

    <div>
        <h1>Gestionar Materias</h1>
        <p>Administración de materias y correlatividades.</p>
    </div>

    <div>
        <a href="/admin/panel" class="btn btn-secondary">
            ← Volver
        </a>

        <a href="/admin/materias/new" class="btn btn-primary">
            ➕ Nueva Materia
        </a>
    </div>

</div>

<form class="filter-row" action="/admin/materias" method="GET">

    <select name="carrera">

        <option value="">
            Todas las carreras
        </option>

        {{#carreras}}
        <option value="{{id_carrera}}" {{selected}}>
            {{nombreCarrera}}
        </option>
        {{/carreras}}

    </select>

    <button type="submit" class="btn btn-secondary">
        Filtrar
    </button>

</form>

<div class="grid">

    {{#materias}}
    <div class="card">

        <div class="details">

            <h2>{{nombreMateria}}</h2>

            <p>
                <strong>Año:</strong> {{anio}}
            </p>

            <p>
                <strong>Cuatrimestre:</strong> {{cuatrimestre}}
            </p>

            <p>
                <strong>Carga horaria:</strong> {{carga_horaria}} hs
            </p>

            <p>
                <strong>Carrera:</strong> {{nombreCarrera}}
            </p>

            <p>
                <strong>Plan de estudio:</strong>
                {{#planAnio}}{{planAnio}}{{/planAnio}}
                {{^planAnio}}Sin plan{{/planAnio}}
            </p>

        </div>

        <div class="actions">

            <a href="/admin/materias/edit/{{id_materia}}" class="edit">
                ✏️ Editar
            </a>

            <a href="/admin/materias/correlativas/{{id_materia}}" class="link">
                🔗 Correlativas
            </a>

            <form
                action="/admin/materias/delete/{{id_materia}}"
                method="POST"
                onsubmit="return confirmarEliminacion('{{nombreMateria}}')">

                <button type="submit" class="delete">
                    🗑️ Eliminar
                </button>

            </form>

        </div>

    </div>
    {{/materias}}

    {{^materias}}
    <div class="empty-state">
        No existen materias registradas.
    </div>
    {{/materias}}

</div>
</div>
<script>

function confirmarEliminacion(nombreMateria){

    return confirm(
        "¿Está seguro que desea eliminar la materia:\n\n" +
        nombreMateria +
        "\n\nEsta acción no puede deshacerse."
    );
}

</script>

</body>
</html>