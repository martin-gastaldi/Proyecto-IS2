<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Mis Materias</title>

<style>

body{
    font-family:Segoe UI,sans-serif;
    background:#f5f5f5;
    padding:30px;
}

.container{
    max-width:1100px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:10px;
}

h1{
    margin-bottom:25px;
}

h2{
    margin-top:35px;
    margin-bottom:15px;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#8b1e2d;
    color:white;
    padding:10px;
}

td{
    padding:10px;
    border-bottom:1px solid #ddd;
}

.btn{
    background:#8b1e2d;
    color:white;
    border:none;
    padding:8px 12px;
    border-radius:5px;
    cursor:pointer;
}

.volver{
    margin-top:30px;
    display:inline-block;
}

</style>

</head>
<body>

<div class="container">

<h1>📚 Mis Materias</h1>

<h2>Materias cursadas</h2>

<table>

<tr>
    <th>Materia</th>
    <th>Estado</th>
    <th>Nota</th>
</tr>

{{#materiasCursadas}}
<tr>
    <td>{{nombreMateria}}</td>
    <td>{{estado}}</td>
    <td>{{notaFinal}}</td>
</tr>
{{/materiasCursadas}}

</table>

<h2>Materias disponibles para inscripción</h2>

<table>

<tr>
    <th>Materia</th>
    <th>Año</th>
    <th>Cuatrimestre</th>
    <th></th>
</tr>

{{#materiasDisponibles}}

<tr>

<td>{{nombreMateria}}</td>
<td>{{anio}}</td>
<td>{{cuatrimestre}}</td>

<td>

<form
    method="POST"
    action="/estudiante/materias/inscribir">

    <input
        type="hidden"
        name="id_materia"
        value="{{id_materia}}">

    <button class="btn">
        Inscribirme
    </button>

</form>

</td>

</tr>

{{/materiasDisponibles}}

</table>

<a
    href="/dashboard"
    class="volver">

    ← Volver

</a>

</div>

</body>
</html>