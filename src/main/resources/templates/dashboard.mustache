<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #5b0f1a 0%, #8b1e2d 50%, #b03045 100%);
            min-height: 100vh;
            padding: 30px;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 12px 35px rgba(0,0,0,0.25);
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 4px solid #8b1e2d;
            padding-bottom: 20px;
        }

        .header h1 {
            color: #333;
            font-size: 2.7rem;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 1.1rem;
        }

        .welcome-box {
            background: #fff4f5;
            border-left: 6px solid #8b1e2d;
            padding: 22px;
            border-radius: 10px;
            margin-bottom: 35px;
        }

        .welcome-box p {
            font-size: 1.2rem;
            color: #444;
        }

        .username {
            color: #8b1e2d;
            font-weight: bold;
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .card {
            border: 2px solid #ececec;
            border-radius: 12px;
            padding: 30px;
            transition: 0.3s ease;
            background: #fafafa;
        }

        .card:hover {
            border-color: #8b1e2d;
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(139, 30, 45, 0.2);
        }

        .card .icon {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .card h2 {
            color: #8b1e2d;
            margin-bottom: 15px;
            font-size: 1.7rem;
        }

        .card p {
            color: #666;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .btn {
            display: inline-block;
            padding: 12px 20px;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            background: linear-gradient(135deg, #8b1e2d 0%, #5b0f1a 100%);
            transition: 0.3s;
            font-weight: 600;
        }

        .btn:hover {
            transform: translateY(-2px);
            opacity: 0.95;
        }

        .actions {
            margin-top: 45px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .logout {
            background: linear-gradient(135deg, #cfc6c6 0%, #d1c4c4 100%);
        }

    </style>
</head>

<body>

<div class="container">

    <div class="header">
        <h1>🎓 Panel de Control</h1>
        <p>Sistema de Gestión Académica</p>
    </div>

    <div class="welcome-box">

        {{#username}}
        <p>
            ¡Bienvenido, <span class="username">{{username}}</span>!
        </p>
        {{/username}}

        {{^username}}
        <p>
            ¡Bienvenido al sistema!
        </p>
        {{/username}}

    </div>

    <div class="cards-grid">

        <div class="card">

            <div class="icon">👤</div>

            <h2>Tu Perfil</h2>

            <p>
                Gestiona la información de tu cuenta y visualiza tus datos personales.
            </p>

            <a href="/profile" class="btn">
                Ver Perfil
            </a>

        </div>

        <div class="card">

            <div class="icon">⚙️</div>

            <h2>Configuraciones</h2>

            <p>
                Ajusta las preferencias y personaliza tu experiencia dentro del sistema.
            </p>

            <a href="/settings" class="btn">
                Configuración
            </a>

        </div>

    </div>

    <div class="actions">

        <a href="/" class="btn">
            Ir al Inicio
        </a>

       <a href="/logout" class="btn logout" style="color: red;">
            Cerrar Sesión
       </a>

    </div>

</div>

</body>
</html>