<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro — Universidad</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy:     #0d1b3e;
            --navy-mid: #1a2f5e;
            --navy-soft:#243872;
            --gold:     #c9973a;
            --gold-lt:  #e8bb6a;
            --gold-pale:#fdf3e0;
            --cream:    #faf8f4;
            --muted:    #6b7280;
            --border:   #e5e7eb;
            --red:      #dc2626;
            --green:    #15803d;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
        }

        /* ── LEFT PANEL ── */
        .panel-left {
            display: none;
            width: 42%;
            position: relative;
            background: var(--navy);
            overflow: hidden;
            flex-direction: column;
            justify-content: space-between;
        }

        @media (min-width: 1024px) { .panel-left { display: flex; } }

        .panel-left img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .18;
        }

        .gold-line {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

        .geo {
            position: absolute;
            border: 1px solid rgba(201,151,58,.2);
            border-radius: 2px;
        }
        .geo-1 { width: 220px; height: 220px; top: -50px; right: -50px; transform: rotate(-18deg); }
        .geo-2 { width: 140px; height: 140px; top: 110px; right: 80px; transform: rotate(-8deg); border-color: rgba(201,151,58,.12); }
        .geo-3 { width: 280px; height: 280px; bottom: 60px; left: -70px; transform: rotate(12deg); border-color: rgba(255,255,255,.07); }

        .panel-top {
            position: relative;
            z-index: 2;
            padding: 3rem 3rem 1.5rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(201,151,58,.15);
            border: 1px solid rgba(201,151,58,.35);
            border-radius: 100px;
            padding: 6px 16px;
            font-size: 12px;
            font-weight: 500;
            color: var(--gold-lt);
            letter-spacing: .05em;
            text-transform: uppercase;
            margin-bottom: 1.75rem;
        }

        .badge-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--gold);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .3; }
        }

        .panel-left h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.9rem, 2.8vw, 2.5rem);
            color: #fff;
            line-height: 1.2;
            margin-bottom: 1.25rem;
        }

        .panel-left h1 em {
            font-style: italic;
            color: var(--gold-lt);
        }

        .panel-left p {
            color: rgba(255,255,255,.55);
            font-size: .95rem;
            line-height: 1.8;
            font-weight: 300;
        }

        /* Steps list */
        .steps {
            position: relative;
            z-index: 2;
            padding: 0 3rem 3rem;
        }

        .steps-title {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(255,255,255,.35);
            margin-bottom: 1.25rem;
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 1.1rem;
        }

        .step-num {
            width: 26px; height: 26px;
            flex-shrink: 0;
            border-radius: 50%;
            border: 1.5px solid rgba(201,151,58,.5);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px;
            font-weight: 600;
            color: var(--gold-lt);
            margin-top: 1px;
        }

        .step-text {
            font-size: .85rem;
            color: rgba(255,255,255,.6);
            font-weight: 300;
            line-height: 1.5;
        }

        .step-text strong {
            color: rgba(255,255,255,.85);
            font-weight: 500;
            display: block;
            margin-bottom: 2px;
        }

        /* ── RIGHT PANEL ── */
        .panel-right {
            flex: 1;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 2.5rem 2rem;
            position: relative;
            background: var(--cream);
            overflow-y: auto;
        }

        .panel-right::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
            background-size: 28px 28px;
            opacity: .35;
            pointer-events: none;
        }

        .form-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 480px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem 2.25rem;
            box-shadow:
                0 1px 2px rgba(0,0,0,.04),
                0 4px 12px rgba(0,0,0,.06),
                0 16px 40px rgba(0,0,0,.06);
            animation: slideUp .5s ease both;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .form-card::before {
            content: '';
            position: absolute;
            top: 0; left: 2rem; right: 2rem;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold-lt) 70%, transparent);
            border-radius: 0 0 2px 2px;
        }

        /* Card header */
        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.75rem;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            width: 42px; height: 42px;
            background: var(--navy);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
        }

        .brand-icon::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 2px;
            background: var(--gold);
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: .95rem;
            color: var(--navy);
            line-height: 1.2;
        }

        .brand-sub {
            font-size: 11px;
            color: var(--muted);
            font-weight: 300;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .step-pill {
            font-size: 11px;
            font-weight: 600;
            color: var(--gold);
            background: var(--gold-pale);
            border: 1px solid rgba(201,151,58,.3);
            border-radius: 100px;
            padding: 4px 12px;
            letter-spacing: .04em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        /* Section dividers */
        .section-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            border-bottom: 1px solid var(--border);
            padding-bottom: 8px;
            margin: 1.5rem 0 1.1rem;
        }

        .section-label:first-of-type { margin-top: 0; }

        /* Two-column grid */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        /* Fields */
        .field { margin-bottom: 1rem; }
        .field.full { grid-column: 1 / -1; }

        label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .78rem;
            font-weight: 600;
            color: var(--navy);
            letter-spacing: .04em;
            text-transform: uppercase;
            margin-bottom: .45rem;
        }

        label .req {
            color: var(--gold);
            font-size: .85em;
        }

        .input-wrap { position: relative; }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%; transform: translateY(-50%);
            color: #9ca3af;
            font-size: .95rem;
            pointer-events: none;
            transition: color .2s;
            display: flex;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="number"] {
            width: 100%;
            height: 46px;
            padding: 0 14px 0 42px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: .9rem;
            color: var(--navy);
            background: #fafafa;
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
            -moz-appearance: textfield;
        }

        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button { -webkit-appearance: none; }

        input:focus {
            border-color: var(--navy-soft);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(36,56,114,.08);
        }

        .input-wrap:focus-within .input-icon { color: var(--navy-soft); }

        input.has-right { padding-right: 44px; }

        .toggle-pw {
            position: absolute;
            right: 13px;
            top: 50%; transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9ca3af;
            padding: 0;
            display: flex;
            transition: color .2s;
        }

        .toggle-pw:hover { color: var(--navy); }

        .field-hint {
            font-size: .75rem;
            color: #9ca3af;
            margin-top: 5px;
            font-weight: 300;
        }

        /* Password strength */
        .pw-strength {
            display: flex;
            gap: 4px;
            margin-top: 7px;
            opacity: 0;
            transition: opacity .3s;
        }
        .pw-strength.visible { opacity: 1; }
        .dot { width: 22px; height: 3px; border-radius: 2px; background: var(--border); transition: background .3s; }
        .dot.weak   { background: #ef4444; }
        .dot.medium { background: var(--gold); }
        .dot.strong { background: var(--green); }
        .pw-label { font-size: .72rem; color: #9ca3af; margin-left: 4px; font-weight: 400; align-self: center; }

        /* Submit */
        .btn-submit {
            width: 100%;
            height: 50px;
            margin-top: 1.5rem;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            font-weight: 600;
            letter-spacing: .02em;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: background .25s, transform .15s;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(201,151,58,.25) 50%, transparent 100%);
            transform: translateX(-100%);
            transition: transform .6s ease;
        }

        .btn-submit:hover { background: var(--navy-mid); }
        .btn-submit:hover::before { transform: translateX(100%); }
        .btn-submit:active { transform: scale(.98); }

        .btn-content {
            position: relative;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }

        /* Footer */
        .form-footer {
            margin-top: 1.25rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .6rem;
        }

        .form-footer p { font-size: .875rem; color: var(--muted); }

        .link-primary {
            color: var(--navy);
            font-weight: 600;
            text-decoration: none;
            border-bottom: 1px solid var(--gold);
            padding-bottom: 1px;
            transition: color .2s, border-color .2s;
        }

        .link-primary:hover { color: var(--gold); border-color: transparent; }

        .link-back {
            font-size: .8rem;
            color: #9ca3af;
            text-decoration: none;
            transition: color .2s;
        }

        .link-back:hover { color: var(--navy); }

        /* Validation feedback */
        input.valid   { border-color: #86efac; }
        input.invalid { border-color: #fca5a5; }
    </style>
</head>
<body>

<!-- ── LEFT PANEL ── -->
<div class="panel-left">
    <div class="gold-line"></div>
    <img src="/img/universidad2.png" alt="Campus universitario">
    <div class="geo geo-1"></div>
    <div class="geo geo-2"></div>
    <div class="geo geo-3"></div>

    <div class="panel-top">
        <div class="badge">
            <div class="badge-dot"></div>
            Nuevo registro
        </div>

        <h1>Comenzá tu <em>trayectoria</em> académica.</h1>

        <p>Creá tu cuenta institucional en menos de dos minutos y accedé a todos los recursos de la plataforma.</p>
    </div>

    <div class="steps">
        <div class="steps-title">Cómo funciona</div>

        <div class="step">
            <div class="step-num">1</div>
            <div class="step-text">
                <strong>Completá el formulario</strong>
                Ingresá tus datos personales e institucionales.
            </div>
        </div>

        <div class="step">
            <div class="step-num">2</div>
            <div class="step-text">
                <strong>Activá tu cuenta</strong>
                Recibirás un correo de confirmación en tu casilla.
            </div>
        </div>

        <div class="step">
            <div class="step-num">3</div>
            <div class="step-text">
                <strong>Accedé al portal</strong>
                Iniciá sesión y explorá todos los servicios académicos.
            </div>
        </div>
    </div>
</div>

<!-- ── RIGHT PANEL ── -->
<div class="panel-right">
    <div class="form-card">

        <!-- Header -->
        <div class="card-header">
            <div class="brand">
                <div class="brand-icon">🎓</div>
                <div>
                    <div class="brand-name">Portal Académico</div>
                    <div class="brand-sub">Registro institucional</div>
                </div>
            </div>
            <div class="step-pill">Paso 1 de 1</div>
        </div>

        <form action="/user/new" method="post" id="regForm" novalidate>

            <!-- Datos personales -->
            <div class="section-label">Datos personales</div>

            <div class="grid-2">
                <div class="field">
                    <label for="realName">Nombre <span class="req">*</span></label>
                    <div class="input-wrap">
                        <input type="text" id="realName" name="realName" required placeholder="Juan">
                        <span class="input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </span>
                    </div>
                </div>

                <div class="field">
                    <label for="surname">Apellido <span class="req">*</span></label>
                    <div class="input-wrap">
                        <input type="text" id="surname" name="surname" required placeholder="Pérez">
                        <span class="input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </span>
                    </div>
                </div>

                <div class="field full">
                    <label for="dni">DNI <span class="req">*</span></label>
                    <div class="input-wrap">
                        <input type="number" id="dni" name="dni" required placeholder="12 345 678" min="1000000" max="99999999">
                        <span class="input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        </span>
                    </div>
                    <div class="field-hint">Sin puntos ni espacios</div>
                </div>
            </div>

            <!-- Datos de acceso -->
            <div class="section-label">Datos de acceso</div>

            <div class="field">
                <label for="correo">Correo electrónico <span class="req">*</span></label>
                <div class="input-wrap">
                    <input type="email" id="correo" name="correo" required placeholder="juan@universidad.edu">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                </div>
            </div>

            <div class="field">
                <label for="name">Nombre de usuario <span class="req">*</span></label>
                <div class="input-wrap">
                    <input type="text" id="name" name="name" required placeholder="juan.perez" autocomplete="username">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>
                    </span>
                </div>
                <div class="field-hint">Solo letras, números y puntos</div>
            </div>

            <div class="field">
                <label for="password">Contraseña <span class="req">*</span></label>
                <div class="input-wrap">
                    <input type="password" id="password" name="password" required placeholder="••••••••" class="has-right" autocomplete="new-password">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </span>
                    <button type="button" class="toggle-pw" id="togglePw" aria-label="Mostrar contraseña">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
                <div class="pw-strength" id="pwStrength">
                    <div class="dot" id="d1"></div>
                    <div class="dot" id="d2"></div>
                    <div class="dot" id="d3"></div>
                    <div class="dot" id="d4"></div>
                    <span class="pw-label" id="pwLabel"></span>
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-submit">
                <div class="btn-content">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    <span>Crear cuenta</span>
                </div>
            </button>

        </form>

        <div class="form-footer">
            <p>¿Ya tenés cuenta? <a href="/" class="link-primary">Iniciá sesión</a></p>
            <a href="/" class="link-back">← Volver al inicio</a>
        </div>

    </div>
</div>

<script>
    // Toggle password visibility
    const pwInput  = document.getElementById('password');
    const toggleBtn = document.getElementById('togglePw');
    const eyeIcon  = document.getElementById('eyeIcon');

    const eyeOpen  = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    const eyeClose = `<line x1="17.94" y1="17.94" x2="22" y2="22"/><line x1="1" y1="1" x2="6.06" y2="6.06"/><path d="M9.9 4.24A9 9 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M6.24 6.24A18.5 18.5 0 0 0 1 12c0 0 4 8 11 8a9.74 9.74 0 0 0 4.76-1.24"/><line x1="1" y1="1" x2="22" y2="22"/>`;

    toggleBtn.addEventListener('click', () => {
        const isText = pwInput.type === 'text';
        pwInput.type = isText ? 'password' : 'text';
        eyeIcon.innerHTML = isText ? eyeOpen : eyeClose;
    });

    // Password strength
    const pwStrength = document.getElementById('pwStrength');
    const dots = [document.getElementById('d1'), document.getElementById('d2'), document.getElementById('d3'), document.getElementById('d4')];
    const pwLabel = document.getElementById('pwLabel');
    const labels = ['', 'Débil', 'Regular', 'Buena', 'Excelente'];
    const classes = ['', 'weak', 'medium', 'medium', 'strong'];

    pwInput.addEventListener('input', () => {
        const val = pwInput.value;
        if (!val) { pwStrength.classList.remove('visible'); return; }
        pwStrength.classList.add('visible');

        let score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^a-zA-Z0-9]/.test(val)) score++;

        dots.forEach((dot, i) => {
            dot.className = 'dot';
            if (i < score) dot.classList.add(classes[score]);
        });

        pwLabel.textContent = labels[score] || '';
        pwLabel.style.color = score <= 1 ? '#ef4444' : score <= 2 ? 'var(--gold)' : 'var(--green)';
    });

    // Live validation feedback
    const validateRules = {
        realName: v => v.trim().length >= 2,
        surname:  v => v.trim().length >= 2,
        dni:      v => /^\d{7,8}$/.test(v.trim()),
        correo:   v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()),
        name:     v => /^[a-zA-Z0-9.]{3,}$/.test(v.trim()),
        password: v => v.length >= 6,
    };

    Object.keys(validateRules).forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('blur', () => {
            const ok = validateRules[id](el.value);
            el.classList.toggle('valid',   ok);
            el.classList.toggle('invalid', !ok && el.value !== '');
        });
        el.addEventListener('input', () => {
            if (el.classList.contains('invalid') && validateRules[id](el.value)) {
                el.classList.remove('invalid');
                el.classList.add('valid');
            }
        });
    });
</script>

</body>
</html>