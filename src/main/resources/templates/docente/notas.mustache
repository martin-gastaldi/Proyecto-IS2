<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="UTF-8">

<title>Carga de Notas</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Segoe UI',sans-serif;
    background:linear-gradient(
        135deg,
        #1cae41 0%,
        #3a8e48 100%
    );
    min-height:100vh;
    padding:30px;
}

.container{
    max-width:1200px;
    margin:auto;
    background:white;
    border-radius:12px;
    padding:40px;
    box-shadow:0 10px 40px rgba(0,0,0,.2);
}

.header{
    text-align:center;
    margin-bottom:30px;
    border-bottom:3px solid #1cae41;
    padding-bottom:20px;
}

.header h1{
    color:#333;
    margin-bottom:10px;
}

.header p{
    color:#666;
}

.selector{
    background:#e8f5e9;
    border-left:5px solid #1cae41;
    padding:20px;
    border-radius:8px;
    margin-bottom:30px;
}

select,
input{
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #ccc;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:20px;
}

th{
    background:#1cae41;
    color:white;
    padding:12px;
}

td{
    padding:12px;
    border-bottom:1px solid #ddd;
}

tr:hover{
    background:#f7f7f7;
}

.btn{
    padding:10px 18px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    text-decoration:none;
}

.btn-primary{
    background:#1cae41;
    color:white;
}

.btn-primary:hover{
    background:#157c30;
}

.btn-secondary{
    background:#ddd;
    color:#333;
}

.footer{
    margin-top:25px;
    text-align:center;
}

.empty{
    text-align:center;
    color:#777;
    padding:30px;
}

</style>

</head>
<body>

<div class="container">

    <div class="header">
        <h1>📝 Carga de Notas</h1>
        <p>Seleccione una materia y cargue las notas</p>
    </div>

    <div class="selector">

        <form
            action="/docente/notas/materia"
            method="GET">

            <label>
                Materia
            </label>

            <select name="id_materia">

                {{#materias}}

                <option
                    value="{{id_materia}}"
                    {{#selected}}selected{{/selected}}>
                    {{nombreMateria}}
                </option>

                {{/materias}}

            </select>

            <br><br>

            <button
                type="submit"
                class="btn btn-primary">

                Ver alumnos

            </button>

        </form>

    </div>

    {{#alumnos}}

    <table>

        <thead>
            <tr>
                <th>DNI</th>
                <th>Alumno</th>
                <th>Nota</th>
                <th>Estado</th>
                <th>Guardar</th>
            </tr>
        </thead>

        <tbody>

        {{#alumnos}}

        <tr>

            <form
                action="/docente/notas/guardar"
                method="POST">

                <td>

                    {{dni}}

                    <input
                        type="hidden"
                        name="dniEstudiante"
                        value="{{dni}}">

                    <input
                        type="hidden"
                        name="id_materia"
                        value="{{idMateriaSeleccionada}}">

                </td>

                <td>
                    {{apellido}}, {{nombre}}
                </td>

                <td>

                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        max="10"
                        name="notaFinal"
                        value="{{notaFinal}}">

                </td>

                <td>

                   <select name="estado">

                    <option
                        value="LIBRE"
                        {{#esLibre}}selected{{/esLibre}}>
                        LIBRE
                    </option>

                    <option
                        value="REGULAR"
                        {{#esRegular}}selected{{/esRegular}}>
                        REGULAR
                    </option>

                    <option
                        value="PROMOCIONADA"
                        {{#esPromocionada}}selected{{/esPromocionada}}>
                        PROMOCIONADA
                    </option>

                    <option
                        value="APROBADA"
                        {{#esAprobada}}selected{{/esAprobada}}>
                        APROBADA
                    </option>

                </select>

                </td>

                <td>

                    <button
                        class="btn btn-primary">

                        Guardar

                    </button>

                </td>

            </form>

        </tr>

        {{/alumnos}}

        </tbody>

    </table>

    {{/alumnos}}

    {{^alumnos}}

    <div class="empty">

        No hay alumnos para mostrar.
        Seleccione una materia.

    </div>

    {{/alumnos}}

    <div class="footer">

        <a
            href="/docente/dashboard"
            class="btn btn-secondary">

            ← Volver al Panel

        </a>

    </div>

</div>

</body>
</html>