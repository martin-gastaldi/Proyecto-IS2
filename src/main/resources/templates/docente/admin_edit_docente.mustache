<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Docente</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            margin: 0;
            padding: 30px;
        }

        .container {
            max-width: 650px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            padding: 26px;
            box-shadow: 0 20px 55px rgba(0,0,0,0.18);
        }

        .header {
            display:flex;
            justify-content:space-between;
            align-items:center;
            gap:10px;
            margin-bottom:24px;
        }

        .header h1 {
            margin:0;
            font-size:2rem;
            color:#333;
        }

        .button {
            display:inline-block;
            padding:12px 18px;
            border-radius:8px;
            text-decoration:none;
            color:white;
            font-weight:600;
        }
        
        .button.secondary {
            background:#6c757d;
        }
        
        .form-group {
            margin-bottom:16px;
        }
        
        label {
            display:block;
            margin-bottom:8px;
            color:#333;
            font-weight:600;
        }
        
        input {
            width:100%;
            padding:12px 14px;
            border:1px solid #cbd5e1;
            border-radius:10px;
            box-sizing:border-box;
        }
        
        button {
            padding:14px 18px;
            border:none;
            border-radius:10px;
            background:#f6c23e;
            color:#111;
            font-weight:700;
            cursor:pointer;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div>
            <h1>Editar Docente</h1>
            <p>DNI: {{dni}}</p>
        </div>
        <a href="/admin/docentes" class="button secondary">← Volver</a>
    </div>

    <form action="/admin/docentes/edit" method="POST">
        <input type="hidden" name="dni" value="{{dni}}">

        <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="realName" value="{{docente.nombre}}" required>
        </div>
        <div class="form-group">
            <label>Apellido</label>
            <input type="text" name="surname" value="{{docente.apellido}}" required>
        </div>
        <div class="form-group">
            <label>Correo</label>
            <input type="email" name="correo" value="{{docente.correo}}" required>
        </div>
        <div class="form-group">
            <label>Teléfono</label>
            <input type="text" name="telefono" value="{{docente.telefono}}" required>
        </div>
        <div class="form-group">
            <label>CUIL</label>
            <input type="text" name="cuil" value="{{docente.cuil}}" required>
        </div>
        <div class="form-group">
            <label>Departamento</label>
            <input type="text" name="departament" value="{{docente.departamento}}" required>
        </div>

        <button type="submit">Guardar cambios</button>
    </form>
</div>
</body>
</html>