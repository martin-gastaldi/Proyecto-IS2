<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Docente</title>

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0a8a2a 0%, #48a357 100%);
            min-height: 100vh;
            padding: 30px;
        }

        .container {
            max-width: 1200px;
            margin: auto;
            background: white;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 3px solid #667eea;
            padding-bottom: 20px;
        }

        .header h1 {
            color: #333;
            font-size: 2.5rem;
        }

        .docente-info {
            background: #f5f7ff;
            border-left: 5px solid #667eea;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
        }

        .docente-info p {
            margin: 10px 0;
            color: #444;
        }

        .materias-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .materia-card {
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 25px;
            transition: 0.3s;
        }

        .materia-card:hover {
            border-color: #667eea;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(102,126,234,0.2);
        }

        .materia-card h3 {
            color: #667eea;
            margin-bottom: 15px;
        }

        .materia-card p {
            color: #666;
            margin: 5px 0;
        }

        .btn {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 18px;
            border-radius: 6px;
            text-decoration: none;
            color: white;
            background: linear-gradient(135deg, #347243 0%, #0a300a 100%);
            transition: 0.3s;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .actions {
            margin-top: 40px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .logout {
            background: #f44336;
        }

    </style>
</head>
<body>

<div class="container">

    <div class="header">
        <h1>👨‍🏫 Dashboard Docente</h1>
    </div>

    <div class="docente-info">
        <p><strong>Nombre:</strong> {{docente.nombre}} {{docente.apellido}}</p>
        <p><strong>Departamento:</strong> {{docente.departamento}}</p>
    </div>

    <h2>📚 Materias que dicta</h2>

    <div class="materias-grid">

        {{#materias}}
        <div class="materia-card">

            <h3>{{nombreMateria}}</h3>

            <p><strong>Año:</strong> {{anio}}</p>
            <p><strong>Cuatrimestre:</strong> {{cuatrimestre}}</p>

            <a href="/docente/alumnos/{{id}}" class="btn">
                Ver alumnos
            </a>

        </div>
        {{/materias}}

    </div>

    <div class="actions">

        <a href="/docente/materias" class="btn">
            Ver todas las materias
        </a>

        <a href="/logout" class="btn logout">
            Cerrar sesión
        </a>

    </div>

</div>

</body>
</html>