<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Crear Docente - Sistema Académico</title>

<style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    body{
        font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
        min-height:100vh;
        padding:30px;
    }

    .container{
        max-width:700px;
        margin:0 auto;
        background:white;
        border-radius:12px;
        padding:26px;
        box-shadow:0 20px 55px rgba(0,0,0,0.18);
    }

    .header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap:10px;
        margin-bottom:24px;
    }

    .header h1{
        margin:0;
        font-size:2rem;
        color:#333;
    }

    .header p{
        margin-top:4px;
        color:#666;
    }

    .button{
        display:inline-block;
        padding:12px 18px;
        border-radius:8px;
        text-decoration:none;
        color:white;
        font-weight:600;
    }

    .button.secondary{
        background:#6c757d;
    }

    .alert{
        padding:12px;
        border-radius:10px;
        margin-bottom:20px;
    }

    .alert-success{
        background:#d4edda;
        border:1px solid #c3e6cb;
        color:#155724;
    }

    .alert-error{
        background:#f8d7da;
        border:1px solid #f5c6cb;
        color:#721c24;
    }

    .form-group{
        margin-bottom:16px;
    }

    .form-row{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:16px;
    }

    label{
        display:block;
        margin-bottom:8px;
        color:#333;
        font-weight:600;
    }

    input{
        width:100%;
        padding:12px 14px;
        border:1px solid #cbd5e1;
        border-radius:10px;
        font-size:14px;
        transition:.2s;
    }

    input:focus{
        outline:none;
        border-color:#667eea;
        box-shadow:0 0 0 3px rgba(102,126,234,.15);
    }

    input[type="password"]{
        font-family:'Courier New',monospace;
        letter-spacing:1px;
    }

    .password-info{
        font-size:.85rem;
        color:#666;
        margin-top:6px;
    }

    .required{
        color:#dc3545;
        font-weight:bold;
    }

    .form-footer{
        display:flex;
        justify-content:flex-end;
        margin-top:20px;
    }

    button[type="submit"]{
        padding:14px 18px;
        border:none;
        border-radius:10px;
        background:#f6c23e;
        color:#111;
        font-weight:700;
        cursor:pointer;
        transition:.2s;
    }

    button[type="submit"]:hover{
        opacity:.9;
        transform:translateY(-1px);
    }

    @media (max-width:768px){

        .form-row{
            grid-template-columns:1fr;
        }

        .header{
            flex-direction:column;
            align-items:flex-start;
        }

    }

</style>
</head>

<body>

<div class="container">

    <div class="header">

        <div>
            <h1>👨‍🏫 Crear Docente</h1>
            <p>Registrar un nuevo docente en el sistema</p>
        </div>

        <a href="/admin/docentes" class="button secondary">
            ← Volver
        </a>

    </div>

    {{#successMessage}}
    <div class="alert alert-success">
        ✓ {{successMessage}}
    </div>
    {{/successMessage}}

    {{#errorMessage}}
    <div class="alert alert-error">
        ✗ {{errorMessage}}
    </div>
    {{/errorMessage}}

    <form action="/get_docente" method="POST">

        <div class="form-group">
            <label for="username">
                Nombre de Usuario
                <span class="required">*</span>
            </label>

            <input
                type="text"
                id="username"
                name="username"
                required
                placeholder="ej: jperez">
        </div>

        <div class="form-group">
            <label for="password">
                Contraseña
                <span class="required">*</span>
            </label>

            <input
                type="password"
                id="password"
                name="password"
                required
                minlength="6"
                placeholder="Mínimo 6 caracteres">

            <div class="password-info">
                La contraseña debe contener al menos 6 caracteres
            </div>
        </div>

        <div class="form-group">
            <label for="dni">
                DNI
                <span class="required">*</span>
            </label>

            <input
                type="number"
                id="dni"
                name="dni"
                required
                min="1000000"
                max="99999999"
                placeholder="ej: 12345678">
        </div>

        <div class="form-group">
            <label for="cuil">
                CUIL
                <span class="required">*</span>
            </label>

            <input
                type="text"
                id="cuil"
                name="cuil"
                required
                placeholder="20-12345678-3"
                pattern="[0-9]{2}-[0-9]{8}-[0-9]"
                title="Formato: 20-12345678-3">
        </div>

        <div class="form-row">

            <div class="form-group">
                <label for="realName">
                    Nombre
                    <span class="required">*</span>
                </label>

                <input
                    type="text"
                    id="realName"
                    name="realName"
                    required
                    placeholder="ej: Juan">
            </div>

            <div class="form-group">
                <label for="surname">
                    Apellido
                    <span class="required">*</span>
                </label>

                <input
                    type="text"
                    id="surname"
                    name="surname"
                    required
                    placeholder="ej: Pérez">
            </div>

        </div>

        <div class="form-group">
            <label for="correo">
                Correo Electrónico
                <span class="required">*</span>
            </label>

            <input
                type="email"
                id="correo"
                name="correo"
                required
                placeholder="ej: docente@universidad.edu.ar">
        </div>

        <div class="form-row">

            <div class="form-group">
                <label for="telefono">
                    Teléfono
                    <span class="required">*</span>
                </label>

                <input
                    type="text"
                    id="telefono"
                    name="telefono"
                    required
                    placeholder="ej: 3584123456">
            </div>

            <div class="form-group">
                <label for="departament">
                    Departamento
                    <span class="required">*</span>
                </label>

                <input
                    type="text"
                    id="departament"
                    name="departament"
                    required
                    placeholder="ej: Departamento de Computación">
            </div>

        </div>

        <div class="form-footer">

            <button type="submit">
                Crear Docente
            </button>

        </div>

    </form>

</div>

</body>
</html>