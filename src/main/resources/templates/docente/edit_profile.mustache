<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar mis datos</title>

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1cae41 0%, #3a8e48 100%);
            min-height: 100vh;
            margin: 0;
            padding: 30px;
        }

        .container {
            width: 100%;
            max-width: 650px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            padding: 40px;
            margin: 0 auto;
        }

        .header {
            display:flex;
            justify-content:space-between;
            align-items:center;
            gap:10px;
            margin-bottom:24px;
        }

        .header h1 {
            margin:0;
            font-size:2rem;
            color:#333;
        }

        .header p {
            margin:4px 0 0;
            color:#666;
        }

        .button {
            display:inline-block;
            padding:12px 18px;
            border-radius:8px;
            text-decoration:none;
            color:white;
            font-weight:600;
        }
        
        .button.secondary {
            background:#6c757d;
        }
        
        .form-group {
            margin-bottom:16px;
        }
        
        label {
            display:block;
            margin-bottom:8px;
            color:#333;
            font-weight:600;
        }
        
        input {
            width:100%;
            padding:12px 14px;
            border:1px solid #cbd5e1;
            border-radius:10px;
            box-sizing:border-box;
        }
        
        button {
            padding:14px 18px;
            border:none;
            border-radius:10px;
            background: linear-gradient(135deg, #1cae41 0%, #0d7a2e 100%);
            color:white;
            font-weight:700;
            cursor:pointer;
        }

        button:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(28, 174, 65, 0.3);
        }

        .message {
            padding: 14px 18px;
            border-radius: 9px;
            margin-bottom: 20px;
            font-weight: 600;
        }
        
        .message.error {
            background: #f8d7da;
            color: #721c24;
        }

        .separator {
            border-top: 2px solid #e0e0e0;
            margin: 24px 0;
            padding-top: 24px;
        }

        .separator h3 {
            margin: 0 0 16px 0;
            color: #1cae41;
            font-size: 1.1rem;
        }

        .separator p {
            margin: 0 0 16px 0;
            color: #666;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>

<div class="container">

    <div class="header">
        <div>
            <h1>Editar mis datos</h1>
            <p>DNI: {{dni}}</p>
        </div>
        <a href="/docente/dashboard" class="button secondary">← Volver</a>
    </div>

    {{#errorMessage}}
    <div class="message error">{{errorMessage}}</div>
    {{/errorMessage}}

    <form action="/docente/perfil/editar" method="POST">
        <input type="hidden" name="dni" value="{{dni}}">

        <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="realName" value="{{docente.nombre}}" required>
        </div>
        <div class="form-group">
            <label>Apellido</label>
            <input type="text" name="surname" value="{{docente.apellido}}" required>
        </div>
        <div class="form-group">
            <label>Correo</label>
            <input type="email" name="correo" value="{{docente.correo}}" required>
        </div>
        <div class="form-group">
            <label>Teléfono</label>
            <input type="text" name="telefono" value="{{docente.telefono}}" required>
        </div>
        <div class="form-group">
            <label>CUIL</label>
            <input type="text" name="cuil" value="{{docente.cuil}}" required>
        </div>
        <div class="form-group">
            <label>Departamento</label>
            <input type="text" name="departament" value="{{docente.departamento}}" required>
        </div>

        <div class="separator">
            <h3>🔐 Cambiar contraseña (Opcional)</h3>
            <p>Deja en blanco si no deseas cambiar tu contraseña.</p>
            <div class="form-group">
                <label>Nueva contraseña</label>
                <input type="password" id="password" name="password" autocomplete="new-password" placeholder="Ingresa una nueva contraseña">
            </div>
            <div class="form-group">
                <label>Confirmar contraseña</label>
                <input type="password" id="password_confirm" name="password_confirm" autocomplete="new-password" placeholder="Confirma tu nueva contraseña">
            </div>
        </div>

        <button type="submit">💾 Guardar cambios</button>
    </form>

</div>

</body>
</html>