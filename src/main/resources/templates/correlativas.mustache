<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Administrar Correlativas</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
    background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
    min-height:100vh;
    padding:30px;
}

.container{
    max-width:800px;
    margin:0 auto;
    background:white;
    border-radius:12px;
    padding:30px;
    box-shadow:0 20px 55px rgba(0,0,0,0.18);
}

.header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
    margin-bottom:24px;
}

.header h1{
    margin:0;
    font-size:2rem;
    color:#333;
}

.header p{
    margin-top:6px;
    color:#666;
}

.button{
    display:inline-block;
    padding:12px 18px;
    border-radius:8px;
    text-decoration:none;
    color:white;
    font-weight:600;
}

.button.secondary{
    background:#6c757d;
}

table{
    width:100%;
    border-collapse:collapse;
    margin:24px 0;
}

thead{
    background:#f8f9fc;
}

th{
    text-align:left;
    color:#333;
    font-weight:600;
}

th,
td{
    padding:12px;
    border-bottom:1px solid #e5e7eb;
}

.empty-row{
    text-align:center;
    color:#666;
}

.form-section{
    margin-top:30px;
}

.form-section h2{
    margin-bottom:16px;
    color:#333;
}

.form-group{
    margin-bottom:16px;
}

label{
    display:block;
    margin-bottom:6px;
    color:#333;
    font-weight:600;
}

select{
    width:100%;
    padding:10px 12px;
    border:1px solid #cbd5e1;
    border-radius:8px;
    box-sizing:border-box;
}

.btn{
    border:none;
    cursor:pointer;
    font-weight:600;
    border-radius:8px;
    transition:.2s;
}

.btn:hover{
    opacity:.95;
}

.btn-success{
    width:100%;
    padding:12px;
    background:#1cc88a;
    color:white;
}

.btn-delete{
    padding:7px 12px;
    background:#fd7e14;
    color:white;
}

</style>
</head>

<body>

<div class="container">

    <div class="header">
        <div>
            <h1>Correlativas</h1>
            <p>Materia: {{materia.nombreMateria}}</p>
        </div>

        <a href="/admin/materias" class="button secondary">
            ← Volver
        </a>
    </div>

    <table>

        <thead>
            <tr>
                <th>Materia correlativa</th>
                <th>Condición</th>
                <th>Acción</th>
            </tr>
        </thead>

        <tbody>

        {{#correlativas}}

            <tr>

                <td>{{nombreCorrelativa}}</td>

                <td>{{condicion}}</td>

                <td>

                    <form
                        action="/admin/materias/correlativas/delete"
                        method="POST"
                        onsubmit="return confirm('¿Eliminar correlativa?')">

                        <input
                            type="hidden"
                            name="id_materia"
                            value="{{idMateria}}">

                        <input
                            type="hidden"
                            name="id_correlativa"
                            value="{{id_correlativa}}">

                        <button
                            type="submit"
                            class="btn btn-delete">
                            ➖ Eliminar
                        </button>

                    </form>

                </td>

            </tr>

        {{/correlativas}}

        {{^correlativas}}

            <tr>
                <td colspan="3" class="empty-row">
                    Sin correlativas cargadas
                </td>
            </tr>

        {{/correlativas}}

        </tbody>

    </table>

    <div class="form-section">

        <h2>Agregar correlativa</h2>

        <form
            action="/admin/materias/correlativas/add"
            method="POST">

            <input
                type="hidden"
                name="id_materia"
                value="{{idMateria}}">

            <div class="form-group">

                <label>Materia</label>

                <select name="id_correlativa" required>

                    <option value="">
                        Seleccionar materia
                    </option>

                    {{#materiasDisponibles}}

                    <option value="{{id_materia}}">
                        {{nombreMateria}}
                    </option>

                    {{/materiasDisponibles}}

                </select>

            </div>

            <div class="form-group">

                <label>Condición</label>

                <select name="condicion">

                    <option value="REGULAR">
                        REGULAR
                    </option>

                    <option value="APROBADA">
                        APROBADA
                    </option>

                </select>

            </div>

            <button
                type="submit"
                class="btn btn-success">
                Guardar correlativa
            </button>

        </form>

    </div>

</div>

</body>
</html>